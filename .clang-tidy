# clang-tidy 配置 — can-dash 车规项目 (ASIL-B)
# 文档：https://clang.llvm.org/extra/clang-tidy/
#
# 选用规则（聚焦真实缺陷，不混入风格噪声）：
#   - cert-*             : CERT Secure Coding (CWE 防护)
#   - bugprone-*         : 常见 bug 模式 (use-after-move, dangling-handle 等)
#   - performance-*      : 性能/资源泄漏
#   - clang-analyzer-*   : 深度静态分析 (null deref, UB, 内存泄漏)
#
# 故意不开的（与车规工程实践冲突或纯风格）：
#   - modernize-*        : 现代 C++ 风格（车规代码偏 C++11/14，保守升级）
#   - readability-*      : 可读性偏好 (identifier-length, magic-numbers 等噪声)
#   - cppcoreguidelines-*: Bjarne 推荐，风格 + 现代 C++，噪声大
#   - hicpp-*            : 与 cert 重叠
#   - llvm-*/google-*/fuchsia-* : 不适用
#
# 注：项目里的 /src/generated/*.h 是从 yamlgen 自动生成的"数据契约"头文件，
#     故意保持 C 风格（typedef、C 数组）以与 QML/外部 C 工具兼容，已在
#     文件头加 NOLINTBEGIN 抑制。

Checks: >-
  -*,
  cert-dcl21-cpp,
  cert-dcl50-cpp,
  cert-dcl58-cpp,
  cert-err34-c,
  cert-err52-cpp,
  cert-err60-cpp,
  cert-msc32-c,
  cert-msc51-cpp,
  cert-msc54-cpp,
  cert-msc57-cpp,
  cert-msc24-c,
  cert-msc33-c,
  cert-msc34-c,
  cert-msc50-cpp,
  cert-msc53-cpp,
  cert-oop11-cpp,
  cert-oop57-cpp,
  cert-oop58-cpp,
  cert-pos44-c,
  cert-pos47-c,
  cert-sig30-c,
  cert-str34-c,
  bugprone-assert-side-effect,
  bugprone-bool-pointer-implicit-conversion,
  bugprone-copy-constructor-init,
  bugprone-dangling-handle,
  bugprone-dynamic-static-initializers,
  bugprone-easily-swappable-parameters,
  bugprone-incorrect-roundings,
  bugprone-integer-division,
  bugprone-macro-parentheses,
  bugprone-misplaced-operator-in-strlen-in-connection,
  bugprone-misplaced-widening-cast,
  bugprone-move-forwarding-reference,
  bugprone-multiple-statement-macro,
  bugprone-narrowing-conversions,
  bugprone-no-escape,
  bugprone-not-null-terminated-result,
  bugprone-reserved-identifier,
  bugprone-sizeof-expression,
  bugprone-spuriously-wake-up-functions,
  bugprone-string-constructor,
  bugprone-string-integer-assignment,
  bugprone-string-literal-with-embedded-nul,
  bugprone-suspicious-include,
  bugprone-suspicious-memory-comparison,
  bugprone-suspicious-missing-comma,
  bugprone-suspicious-realloc-usage,
  bugprone-suspicious-string-compare,
  bugprone-suspicious-string-concat,
  bugprone-suspicious-stringview-data-usage,
  bugprone-switch-missing-default-case,
  bugprone-terminating-continue,
  bugprone-throw-keyword-misplacement,
  bugprone-too-small-loop-variable,
  bugprone-undefined-memory-manipulation,
  bugprone-undelegated-constructor,
  bugprone-unhandled-exceptions-in-main,
  bugprone-unhandled-self-assignment,
  bugprone-unique-ptr-array-mismatch,
  bugprone-unchecked-optional-access,
  bugprone-unused-raii,
  bugprone-use-after-move,
  bugprone-virtual-near-miss,
  performance-faster-string-find,
  performance-for-range-copy,
  performance-implicit-conversion-in-loop,
  performance-inefficient-algorithm,
  performance-inefficient-string-concatenation,
  performance-inefficient-vector-operation,
  performance-move-const-arg,
  performance-move-constructor-init,
  performance-no-automatic-move,
  performance-no-int-to-ptr,
  performance-noexcept-move-constructor,
  performance-noexcept-swap,
  performance-trivially-destructible,
  performance-type-promotion-in-math-fn,
  performance-unnecessary-copy-initialization,
  performance-unnecessary-value-param,
  clang-analyzer-*,
  -clang-analyzer-osx.*,
  -clang-analyzer-llvm.*,
  -clang-analyzer-security.insecureAPI.*,
  -bugprone-easily-swappable-parameters-min-3-characters

# 关键安全检查 → 警告视为错误
WarningsAsErrors: >-
  cert-*,
  bugprone-use-after-move,
  bugprone-dangling-handle,
  bugprone-undefined-memory-manipulation,
  bugprone-unchecked-optional-access,
  performance-no-int-to-ptr,
  clang-analyzer-core.NullDereference,
  clang-analyzer-core.UndefinedBinaryOperatorResult,
  clang-analyzer-core.DivideZero,
  clang-analyzer-core.uninitialized.*,
  clang-analyzer-cplusplus.NewDelete,
  clang-analyzer-cplusplus.NewDeleteLeaks,
  clang-analyzer-cplusplus.Move,
  clang-analyzer-deadcode.*,
  clang-analyzer-optin.cplusplus.*,
  clang-analyzer-unix.*,
  clang-analyzer-alpha.*

# Header 过滤（仅检查项目手写头；generated/* 和 layer1/display_data.h 是
# tools/yaml_to_c.py 自动生成，外部 C/QML 工具也消费，故意 C 风格已 NOLINT）
# 注：clang-tidy 14 不支持 ExcludeHeaderFilterRegex（v15+），靠 HeaderFilterRegex
#     不匹配 generated/ 路径来跳过。
HeaderFilterRegex: '.*/src/layer[12]/.*\.(h|hpp)$'

# 格式化建议
FormatStyle: file
