# EditorConfig is awesome: https://EditorConfig.org
# Top-most EditorConfig file — applies to whole repo unless overridden.

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.{md}]
trim_trailing_whitespace = false

[*.{cpp,h,hpp,cc,cxx}]
indent_size = 4
max_line_length = 120

[Makefile]
indent_style = tab

[CMakeLists.txt]
indent_size = 4
