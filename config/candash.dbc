BS_:

BU_: BMS VCPU MCU SEAT DRIVER SIM

BO_ 515 VCPU_Frame: 8 Vector__XXX
 SG_ reserved_vcpu : 0|8@1+ (1,0) [0|255] ""  Vector__XXX
 SG_ brake : 8|8@1+ (0.4,0) [0|100] "%"  Vector__XXX
 SG_ vehicle_speed : 24|16@1+ (0.1,0) [0|6553.5] "km/h"  Vector__XXX

BO_ 257 MCU_Frame: 8 Vector__XXX
 SG_ motor_rpm : 0|16@1- (1,0) [-32768|32767] "rpm"  Vector__XXX
 SG_ reserved_mcu : 16|16@1+ (1,0) [0|65535] ""  Vector__XXX
 SG_ motor_temp : 32|8@1+ (1,-40) [-40|215] "degC"  Vector__XXX

BO_ 752 SEAT_Frame: 8 Vector__XXX
 SG_ driver_occupied : 0|1@1+ (1,0) [0|1] ""  Vector__XXX
 SG_ reserved_seat1 : 1|7@1+ (1,0) [0|127] ""  Vector__XXX

BO_ 753 SEAT_P_Frame: 8 Vector__XXX
 SG_ passenger_occupied : 0|1@1+ (1,0) [0|1] ""  Vector__XXX
 SG_ reserved_seat2 : 1|7@1+ (1,0) [0|127] ""  Vector__XXX

BO_ 944 SEAT_BELT_Frame: 8 Vector__XXX
 SG_ driver_buckled : 0|1@1+ (1,0) [0|1] ""  Vector__XXX
 SG_ reserved_belt1 : 1|7@1+ (1,0) [0|127] ""  Vector__XXX

BO_ 945 SEAT_BELT_P_Frame: 8 Vector__XXX
