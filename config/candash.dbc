CM_ "Generated from can-dash config/can_ids.yaml - 真实车机 DBC 格式示例";
CM_ "注: 原 can_ids.yaml 中 0x186040F3 是 29-bit 扩展 ID (BMS_Frame), DBC 标准格式不直接支持, 这里用 11-bit 标准 ID 演示 DBC 解析流程";
CM_ BO_ 515 "VCPU 整车控制器 - 制动/车速 (50ms)";
CM_ BO_ 257 "MCU 电机控制器 - 转速/温度 (100ms)";
CM_ SG_ 515 vehicle_speed "车速 (0-6553.5 km/h, 0.1 分辨率)";
CM_ SG_ 257 motor_rpm "电机转速 (-32768~32767 rpm)";
CM_ SG_ 257 motor_temp "电机温度 (-40~215°C)";


BA_DEF_ BO_  "GenMsgCycleTime" INT 0 65535;

BA_ "GenMsgCycleTime" BO_ 515 50;
BA_ "GenMsgCycleTime" BO_ 257 100;
BA_ "GenMsgCycleTime" BO_ 752 500;
BA_ "GenMsgCycleTime" BO_ 753 500;
BA_ "GenMsgCycleTime" BO_ 944 200;
BA_ "GenMsgCycleTime" BO_ 945 200;
BA_ "GenMsgCycleTime" BO_ 946 200;
BA_ "GenMsgCycleTime" BO_ 773 100;
BA_ "GenMsgCycleTime" BO_ 774 200;
BA_ "GenMsgCycleTime" BO_ 770 200;
BA_ "GenMsgCycleTime" BO_ 768 200;
BA_ "GenMsgCycleTime" BO_ 775 1000;
BA_ "GenMsgCycleTime" BO_ 776 1000;
BA_ "GenMsgCycleTime" BO_ 777 500;
BA_ "GenMsgCycleTime" BO_ 928 200;
BA_ "GenMsgCycleTime" BO_ 929 200;
BA_ "GenMsgCycleTime" BO_ 930 200;
BA_ "GenMsgCycleTime" BO_ 931 200;


VAL_ 515 vehicle_speed 0 "STOPPED" 50 "CITY" 120 "HIGHWAY" ;
VAL_ 257 motor_rpm 0 "IDLE" 3000 "CRUISE" 7000 "REDLINE" ;
VAL_ 768 energy_mode 0 "EV" 1 "HYBRID" 2 "ENGINE" 3 "CHARGING" 4 "OFF" ;
VAL_ 777 gear_status 0 "P" 1 "R" 2 "N" 3 "D" ;
