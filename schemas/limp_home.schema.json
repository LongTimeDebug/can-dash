{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Limp Home Configuration Schema",
  "description": "Limp home (跛行模式) trigger/recovery configuration for can-dash. Three escalation levels (L1/L2/L3) based on critical signal timeouts.",
  "type": "object",
  "required": ["limp_home"],
  "properties": {
    "limp_home": {
      "type": "object",
      "required": ["trigger_l1", "trigger_l2", "trigger_l3", "recovery", "messages"],
      "properties": {
        "trigger_l1": {
          "type": "object",
          "description": "L1 trigger: single critical signal timeout (轻度跛行)",
          "required": ["timeout_ms", "min_timeout_signals", "critical_signals"],
          "properties": {
            "timeout_ms": {
              "type": "integer",
              "minimum": 50,
              "maximum": 10000,
              "description": "Per-signal timeout before L1 is considered (ms)"
            },
            "min_timeout_signals": {
              "type": "integer",
              "minimum": 1,
              "maximum": 8,
              "description": "Minimum count of timed-out signals to trigger L1"
            },
            "critical_signals": {
              "type": "array",
              "minItems": 1,
              "maxItems": 8,
              "items": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_]*$",
                "description": "CAN signal display_key (must exist in can_ids.yaml)"
              }
            }
          }
        },
        "trigger_l2": {
          "type": "object",
          "description": "L2 trigger: multiple critical signals timeout (紧急跛行)",
          "required": ["timeout_ms", "min_timeout_signals"],
          "properties": {
            "timeout_ms": {
              "type": "integer",
              "minimum": 100,
              "maximum": 30000,
              "description": "Per-signal timeout before L2 is considered (ms)"
            },
            "min_timeout_signals": {
              "type": "integer",
              "minimum": 1,
              "maximum": 8,
              "description": "Minimum count of timed-out signals to trigger L2"
            }
          }
        },
        "trigger_l3": {
          "type": "object",
          "description": "L3 trigger: all signals timeout (最深跛行, CAN bus disconnect approx.)",
          "required": ["timeout_ms", "min_timeout_signals"],
          "properties": {
            "timeout_ms": {
              "type": "integer",
              "minimum": 500,
              "maximum": 60000,
              "description": "Per-signal timeout before L3 is considered (ms)"
            },
            "min_timeout_signals": {
              "type": "integer",
              "minimum": 1,
              "maximum": 8,
              "description": "Minimum count of timed-out signals to trigger L3 (should == critical_signals count)"
            }
          }
        },
        "recovery": {
          "type": "object",
          "description": "Recovery criteria: how many consecutive valid frames are required to downgrade",
          "required": ["required_valid_frames"],
          "properties": {
            "required_valid_frames": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "description": "Consecutive valid frames needed to clear limp home state"
            }
          }
        },
        "messages": {
          "type": "object",
          "description": "Bilingual user-facing messages for each limp level (REQ-i18n-001)",
          "required": ["l1_zh", "l1_en", "l2_zh", "l2_en", "l3_zh", "l3_en"],
          "properties": {
            "l1_zh": { "type": "string", "minLength": 1, "description": "L1 message in Chinese" },
            "l1_en": { "type": "string", "minLength": 1, "description": "L1 message in English" },
            "l2_zh": { "type": "string", "minLength": 1, "description": "L2 message in Chinese" },
            "l2_en": { "type": "string", "minLength": 1, "description": "L2 message in English" },
            "l3_zh": { "type": "string", "minLength": 1, "description": "L3 message in Chinese" },
            "l3_en": { "type": "string", "minLength": 1, "description": "L3 message in English" }
          }
        }
      }
    }
  }
}
